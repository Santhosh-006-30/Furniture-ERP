# =============================================================================
# Shiv Furniture Works ERP — Production Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=production
NEXTAUTH_URL=https://erp.shivfurniture.com
NEXTAUTH_SECRET=replace_with_64_char_random_secret_generated_by_openssl

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default)
DATABASE_URL="file:/app/prisma/prod.db"
# PostgreSQL (for scale, replace SQLite above with this):
# DATABASE_URL="postgresql://user:password@host:5432/erp_db?schema=public"

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=replace_with_64_char_random_secret_min_32_chars

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=erp@shivfurniture.com
EMAIL_PASSWORD=your_app_specific_password

# ─── Payment Gateway (Razorpay) ───────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# LOG_FILE=/app/logs/erp.log

# ─── Feature Flags ────────────────────────────────────────────────────────────
MAINTENANCE_MODE=false

# ─── Security ─────────────────────────────────────────────────────────────────
# Rate limiting (requests per minute per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=10
